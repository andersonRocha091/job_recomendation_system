{
    "name": "@ecommerce-recomendations/backend",
    "version": "1.0.0",
    "description": "E-commerce recommendation system — backend API",
    "main": "src/index.ts",
    "scripts": {
        "start": "tsx src/index.ts",
        "dev": "nodemon --exec tsx src/index.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test:coverage": "jest --coverage"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/tests"
        ],
        "testMatch": [
            "<rootDir>/tests/**/*.test.ts"
        ],
        "moduleNameMapper": {
            "^@core/(.*)$": "<rootDir>/src/core/$1",
            "^@adapters/(.*)$": "<rootDir>/src/adapters/$1"
        },
        "collectCoverageFrom": [
            "src/**/*.ts"
        ],
        "coverageThreshold": {
            "global": {
                "lines": 95,
                "branches": 95,
                "functions": 95,
                "statements": 95
            }
        }
    },
    "dependencies": {
        "@tensorflow/tfjs-node": "^4.22.0",
        "express": "^4.21.2",
        "pg": "^8.13.3"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.14.0",
        "@types/pg": "^8.11.11",
        "jest": "^30.3.0",
        "nodemon": "^3.1.9",
        "ts-jest": "^29.4.9",
        "tsx": "^4.19.3",
        "typescript": "^5.8.3"
    }
}
